    "smoke:cli-bounded": "tsx scripts/smoke-cli-bounded.ts",
    "smoke:github-cli-runtime": "tsx scripts/smoke-github-cli-runtime.ts",
    "smoke:orchestrator-soak": "tsx scripts/smoke-orchestrator-soak.ts",
    "smoke:restart-recovery": "tsx scripts/smoke-restart-recovery.ts",
    "smoke:codex-schema": "tsx scripts/smoke-codex-schema.ts",
    "smoke:codex-app-server": "tsx scripts/smoke-codex-app-server.ts",
    "smoke:codex-live-turn": "tsx scripts/smoke-codex-live-turn.ts",
    "smoke:real-preflight": "tsx scripts/smoke-real-preflight.ts",
    "smoke:ssh-worker-preflight": "tsx scripts/smoke-ssh-worker-preflight.ts",
